DATABASE_URL=
DIRECT_DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://localhost:6379
PORT=4000

# CORS origin for the frontend app (defaults to http://localhost:3000 if unset).
CORS_ORIGIN="http://localhost:3000"

# Note: no SUPABASE_JWT_SECRET needed. Supabase now uses ECC P-256 keys.
# JWT verification is done via JWKS using SUPABASE_URL — no secret to store.
